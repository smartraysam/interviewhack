# ─────────────────────────────────────────────────────────
#  InterviewHack — Frontend Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# [OPTIONAL] Speech-to-text mode:
#   browser  — uses the browser's built-in Web Speech API (Chrome/Edge only, no backend call)
#   whisper  — records audio and sends it to POST /api/transcribe (OpenAI Whisper, all browsers)
# Default: browser
VITE_SPEECH_MODE=browser

# [OPTIONAL] Backend API base URL (only needed for production deployments)
# In development, Vite proxies /api → http://localhost:8080 automatically
# VITE_API_BASE_URL=https://your-backend.example.com
